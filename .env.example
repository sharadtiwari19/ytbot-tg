# Copy this to .env for local testing
# In GitHub, add these as repository Secrets (Settings → Secrets → Actions)

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Your Telegram chat ID (your personal ID or a group/channel ID)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=987654321
